{
  "name": "spellbook",
  "version": "1.15.0",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "format": "biome format --write .",
    "format:md": "prettier --write '**/*.md'",
    "lint": "biome check --error-on-warnings .",
    "lint:fix": "biome check --write --error-on-warnings .",
    "check": "biome check --error-on-warnings .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,json,jsonc}": [
      "biome check --write --error-on-warnings --no-errors-on-unmatched"
    ],
    "*.md": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/bun": "latest",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "bun-plugin-tailwind": "^0.1.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.35.0"
  }
}
